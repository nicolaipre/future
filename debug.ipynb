    "import httpx\n",
    "#curl 127.0.0.1:5555/users/123/lol -H \"Host: example.com\"  \n",
    "#user_id='123', arg2='lol'\n",
    "\n",
    "url = \"http://127.0.0.1:5555/users/123/lol\"\n",
    "headers = {\"Host\": \"example.com\"}\n",
    "\n",
    "response = httpx.get(url, headers=headers)\n",
    "print(response.text)\n",
    "\n"
